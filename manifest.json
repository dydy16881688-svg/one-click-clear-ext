{
  "manifest_version": 3,
  "name": "一键打开/验证器/清理小工具",
  "version": "4.7.0",
  "key": "",
  "description": "一键打开常用网址（Chrome 自动填帐密）、谷歌验证器动态码一键复制、一键登出+清浏览痕迹。",

  "permissions": [
    "cookies",
    "browsingData",
    "storage",
    "tabs",
    "tabGroups",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fontforce.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_title": "一键打开/验证器/清理小工具",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_page": "options.html"
}
